{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": [
      "node",
      "@playwright/test"
    ],
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "playwright.config.ts",
    "playwright.testcases.config.ts",
    "tests/**/*.ts",
    "Test_cases/**/*.ts"
  ]
}
